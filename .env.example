# Research Harness Configuration
# Copy this file to .env (or source as .envrc) and fill in your values.
#   cp .env.example .env
#
# ============================================================================
# MINIMUM REQUIRED  (the pipeline will not work without at least these)
# ============================================================================
# You need ONE of the LLM provider keys below. Everything else is optional.

# --- LLM provider (pick at least one) ---
# OpenAI (ChatGPT / GPT-4 / GPT-4o)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# Anthropic (Claude)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# Kimi / Moonshot (domestic-friendly option, accessible from mainland China)
# Get a key at https://platform.moonshot.cn
KIMI_API_KEY=YOUR_KIMI_API_KEY_HERE


# ============================================================================
# RECOMMENDED  (free, improves paper search; takes 60 seconds to set up)
# ============================================================================

# Semantic Scholar — free tier is 1 req/s without a key. A key gives higher
# limits. Apply at https://www.semanticscholar.org/product/api
S2_API_KEY=YOUR_S2_API_KEY_HERE

# Unpaywall — no account needed, just a contact email. Used for open-access
# PDF lookup by DOI. If you leave this blank, OA PDF discovery is disabled
# but the core pipeline still works.
UNPAYWALL_EMAIL=you@your-domain.com

# OpenAlex — free, no key required. Providing an email puts you in the
# "polite pool" with faster rate limits. Completely optional.
# OPENALEX_MAILTO=you@your-domain.com

# fal.ai — required ONLY if you use figure_generate to render paper figures
# (architecture diagrams, pipeline overviews) via nano-banana-pro. Skip this
# if you don't plan to generate figures — the rest of the pipeline is unaffected.
# Get a key at https://fal.ai/dashboard/keys
FAL_KEY=YOUR_FAL_API_KEY_HERE


# ============================================================================
# OPTIONAL  (only set these if you know you need them)
# ============================================================================

# --- Database ---
# Path to the SQLite paper database (default: .research-harness/pool.db)
# RESEARCH_HARNESS_DB_PATH=~/.research-harness/pool.db

# --- Execution backend ---
# RESEARCH_HARNESS_BACKEND=claude_code   # default: local

# --- Tier routing overrides ---
# Research Harness routes LLM calls by tier:
#   light  -> cheap/fast model  (summarize, classify)
#   medium -> balanced model    (claim_extract, gap_detect, deep_read pass1)
#   heavy  -> max quality model (consistency_check, adversarial review, deep_read pass2)
# Format: provider:model — uncomment to override defaults.
# LLM_ROUTE_LIGHT=openai:gpt-4o-mini
# LLM_ROUTE_MEDIUM=openai:gpt-4o
# LLM_ROUTE_HEAVY=anthropic:claude-opus-4-5
#
# IMPORTANT: by default, light/medium tiers BLOCK `anthropic` provider to
# avoid expensive Anthropic API usage on bulk paper-reading tasks. If you
# want to route medium/light through Anthropic (e.g. via a local proxy),
# set LLM_ROUTE_ALLOW_ANYTHING=1. Without this, the router silently falls
# back to openai:gpt-4o for medium tier; an empty OPENAI_API_KEY then
# produces confusing `'str' object has no attribute 'choices'` errors.
# LLM_ROUTE_ALLOW_ANYTHING=1

# --- Local Anthropic proxy ---
# If you run a local proxy that speaks the Anthropic Messages API, point
# the SDK at it via:
# ANTHROPIC_BASE_URL=http://127.0.0.1:8111
# ANTHROPIC_AUTH_TOKEN=<proxy-token>
# Then list the models your proxy actually accepts in LLM_ROUTE_*:
# LLM_ROUTE_LIGHT=anthropic:claude-haiku-4-5
# LLM_ROUTE_MEDIUM=anthropic:claude-sonnet-4-6
# LLM_ROUTE_HEAVY=anthropic:claude-opus-4-6

# --- Extra CLI providers (heavy/light tier alternatives) ---
# CODEX_ENABLED=1
# CURSOR_AGENT_ENABLED=1
#
# Note: cursor_agent is auto-detected if `which agent` succeeds, so setting
# the env var is optional on machines with the Cursor Agent CLI installed.

# --- Deep-read agent pool (for parallel expansion) ---
# When running a paper expansion job, deep-read is parallelized across a
# pool of available LLM providers (see llm_router.available_providers()).
# Each worker round-robins through the pool and broken providers self-
# quarantine after 2 failures. Override the pool to narrow the fan-out,
# e.g. to drop a provider you don't want hit:
# RESEARCH_HARNESS_DEEP_READ_PROVIDERS=anthropic,openai,kimi,cursor_agent
#
# Max concurrent deep-read workers (default min(8, max(2, pool*2))):
# RESEARCH_HARNESS_DEEP_READ_CONCURRENCY=6
#
# Hard wall-clock cap per deep-read paper (seconds, default 300). If a
# worker's LLM call hangs, the batch treats it as a per-paper failure
# after this many seconds and keeps going on the other workers.
# RESEARCH_HARNESS_DEEP_READ_TIMEOUT=300

# --- Additional paper sources ---
# SEMANTIC_SCHOLAR_API_KEY=           # alias for S2_API_KEY
# OPENALEX_API_KEY=                   # OpenAlex does NOT require a key
# OPENREVIEW_ACCESS_TOKEN=            # for ICLR / NeurIPS / ICML mirrors
# OPENREVIEW_ENABLE=0
# PASA_ENABLE=0                       # paper agent search
# PASA_BASE_URL=
# GOOGLE_SCHOLAR_API_KEY=             # via SerpAPI (paid)
# GOOGLE_SCHOLAR_API_URL=
# SCIHUB_MIRRORS=                     # opt-in; check your jurisdiction

# --- LLM provider overrides (base URL / model) ---
# OPENAI_BASE_URL=
# OPENAI_MODEL=
# ANTHROPIC_BASE_URL=
# ANTHROPIC_MODEL=
# ANTHROPIC_AUTH_TOKEN=
# CODEX_MODEL=
# CURSOR_AGENT_MODEL=
# CHATGPT_API_KEY=
# CHATGPT_BASE_URL=
# CHATGPT_MODEL=
# PAPERINDEX_LLM_MODEL=

# --- Kimi (Moonshot) overrides ---
# KIMI_API_KEY is defined in the MINIMUM REQUIRED section above.
# Defaults target Moonshot's coding endpoint (model: kimi-for-coding).
# Uncomment below only if you want the general-chat endpoint instead.
# KIMI_BASE_URL=https://api.moonshot.cn/v1
# KIMI_MODEL=moonshot-v1-128k

# --- Proxy (if using a local LLM proxy) ---
# PROXY_PORT=8080

# --- Filesystem ---
# Root directory for the repo when running utility scripts from elsewhere.
# Defaults to ~/code/research-harness.
# RESEARCH_HARNESS_ROOT=
